# Скопируй этот файл как `.env` в ТОЙ ЖЕ папке, что и `index.js`, и заполни значения.
# Файл `.env` уже в `.gitignore` — его не коммить, тогда ключи не утекут в git/GitHub.
#
# Загрузка: `config/ConfigManager.js` + `config.js` подхватывают `<корень_проекта>/.env` → `process.env` (секреты не хардкодить в коде).

# --- Minecraft (mineflayer) ---
# MC_HOST=localhost
# MC_PORT=25565
# MC_USERNAME=BotName
# MC_VERSION=1.21.11
# MC_AUTH=offline
# Пароль для online/microsoft (только .env):
# MC_PASSWORD=

# --- AI (опционально; офлайн без ключей возможен) ---
# NVIDIA_API_KEY=
# NVIDIA_MODEL=
# ANTHROPIC_API_KEY=

# STRICT_AI_ENV=1 или RELEASE_STRICT=1 — при старте обязательны OPENAI_API_KEY + ASSISTANT_ID
# STRICT_AI_ENV=0

# --- Сессия / переподключение ---
# AUTO_RECONNECT=1 — после разрыва с сервером снова запустить сессию (экспоненциальная задержка, потолок ниже)
# RECONNECT_MAX_DELAY_MS=30000

# Minecraft: начальный состав пати (никнеймы через запятую). Алиасы: PARTY, COMBAT_FRIENDS, BOT_FRIENDS.
# После первого запуска список хранится в data/party.json; в игре: party add|remove|list|clear (или friend …).
# PARTY=Steve,Alex
# Кто может пользоваться чат-командами бота (пусто = все игроки на сервере):
# ALLOWED_USERS=Steve
#
# Ring patrol (`patrolMode`) и patrol-ноги у defend-point по умолчанию ВЫКЛЮЧЕНЫ (заморожено).
# Включить экспериментально: PATROL_ENABLED=1 (или DEFEND_PATROL_ENABLED=1).

# API-ключ OpenAI (тот же, что для ChatGPT API на platform.openai.com)
OPENAI_API_KEY=

# То же самое под другим именем (удобно, если уже так назвал):
# CHATGPT_API_KEY=

# ID ассистента из раздела Assistants (строка вида asst_...)
ASSISTANT_ID=

# Альтернативное имя переменной:
# OPENAI_ASSISTANT_ID=

# Экономия токенов / нагрузки на Assistants API (см. ai.js)
# После N успешных ответов подряд — новый тред (0 = один тред на всю сессию). Пример: 30
# OPENAI_THREAD_RESET_AFTER_MESSAGES=0
# Поллинг run: старт (мс) и потолок backoff (мс)
# OPENAI_POLL_MS=1000
# OPENAI_POLL_MAX_MS=8000
# Сколько последних сообщений треда запрашивать за раз (2–100, по умолчанию 5)
# OPENAI_FETCH_MESSAGES_LIMIT=5
# OPENAI_LOG_USAGE=0 — не логировать run.usage после completed

# Голос (Silero TTS, Python + sounddevice)
VOICE_ENABLED=1
VOICE_PYTHON_BIN=python
VOICE_MODEL=v5_ru
VOICE_SPEAKER=aidar
VOICE_SAMPLE_RATE=48000
VOICE_OUTPUT_DEVICE=CABLE Input
VOICE_DEVICE_ID=

# Simple Voice Chat (UDP + voicechat:secret). 0 = выключить слой в боте.
VOICECHAT_UDP=1
# Совместимость с модом (см. gradle voicechat_compatibility_version). При несовпадении секрет может не прийти.
VOICECHAT_COMPAT=20
# 1 = лог всех plugin channel (custom_payload), не только voicechat:secret
VOICECHAT_DEBUG_CHANNELS=0
# 1|true|yes|on — UDP голоса на 127.0.0.1; host из voicechat:secret игнорируется (порт из секрета сохраняется).
VOICE_FORCE_LOCAL_UDP=0
# 0 — не подставлять 127.0.0.1 автоматически, когда MC_HOST локальный, а в секрете внешний host (ply.gg).
VOICE_UDP_AUTO_LOOPBACK=1
# Пауза между UDP Mic-кадрами (мс), по умолчанию 18.
VOICE_OPUS_FRAME_MS=18
# Пустых Opus-кадров тишины перед речью (0–16, 0 = выкл.), прогрев джиттер-буфера SVC; по умолчанию 4.
VOICE_UDP_PREAMBLE_FRAMES=4
# Пустых Opus-кадров тишины в конце фразы (0–16), по умолчанию 8.
VOICE_TAIL_SILENCE_FRAMES=8
# Пауза (мс) после последнего аудио кадра перед хвостом тишины.
VOICE_POST_AUDIO_GAP_MS=200
